# OpenAgentQA
# Copy this file to .env and fill in your API key

# Required: OpenRouter API key for running agent tests
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: the active agent (a folder name under Agents/). The web UI's agent
# selector writes this here when you switch. Falls back to the "agent" key in
# open-agent-qa.json, then the first agent folder.
# OPENAGENTQA_AGENT=VibeUE-Unreal
